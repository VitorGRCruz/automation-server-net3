TZ=America/Cuiaba

NODE_ENV=development

# API
APP_HOST=0.0.0.0
APP_PORT=3000
APP_LOG_LEVEL=info
METRICS_ENABLED=true
METRICS_EXPOSURE=protected
WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=3001
HEALTH_CACHE_TTL_MS=10000
HEALTH_READINESS_CACHE_TTL_MS=10000
HEALTH_DETAILS_CACHE_TTL_MS=10000
HEALTH_CHECK_TIMEOUT_MS=3000

# Basic Auth
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
AUTOMATION_RUNTIME_MODE=production
AUTOMATION_DEV_IDEMPOTENCY_SCOPE_STRATEGY=run-scoped
AUTOMATION_DEV_ALLOW_COMPLETED_CHILD_WORKFLOW_RERUN=true
# TEST_RUN_ID is optional for the dev scripts below; when empty they generate and print one
TEST_RUN_ID=
TEMPORAL_CONTROL_MAX_CONCURRENT_WORKFLOW_TASK_EXECUTIONS=40
TEMPORAL_CONTROL_MAX_CONCURRENT_ACTIVITY_TASK_EXECUTIONS=10
TEMPORAL_CONTROL_MAX_CACHED_WORKFLOWS=40
TEMPORAL_ERP_READ_MAX_CONCURRENT_ACTIVITY_TASK_EXECUTIONS=5
TEMPORAL_OPA_MAX_CONCURRENT_ACTIVITY_TASK_EXECUTIONS=10
TEMPORAL_IXC_MAX_CONCURRENT_ACTIVITY_TASK_EXECUTIONS=5
TEMPORAL_ERP_READ_MAX_ACTIVITIES_PER_SECOND=5
TEMPORAL_ERP_READ_MAX_TASK_QUEUE_ACTIVITIES_PER_SECOND=5
TEMPORAL_OPA_MAX_ACTIVITIES_PER_SECOND=10
TEMPORAL_OPA_MAX_TASK_QUEUE_ACTIVITIES_PER_SECOND=10
TEMPORAL_IXC_MAX_ACTIVITIES_PER_SECOND=5
TEMPORAL_IXC_MAX_TASK_QUEUE_ACTIVITIES_PER_SECOND=5
# TEMPORAL_CONTROL_MAX_CONCURRENT_WORKFLOW_TASK_POLLS=10
# TEMPORAL_CONTROL_MAX_CONCURRENT_ACTIVITY_TASK_POLLS=10
# TEMPORAL_ERP_READ_MAX_CONCURRENT_ACTIVITY_TASK_POLLS=5
# TEMPORAL_OPA_MAX_CONCURRENT_ACTIVITY_TASK_POLLS=10
# TEMPORAL_IXC_MAX_CONCURRENT_ACTIVITY_TASK_POLLS=5
CSAT_TRIGGER_SCHEDULE_ENABLED=false
CSAT_TRIGGER_SCHEDULE_ID=csat-start-survey-hourly
CSAT_TRIGGER_SCHEDULE_INTERVAL_MINUTES=60
CSAT_TRIGGER_SCHEDULE_TASK_QUEUE=automation-control
CSAT_TRIGGER_SCHEDULE_WORKFLOW_ID=csat-start-survey/schedule
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_ENABLED=false
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_ID=cobrancas-equipment-retrieval-verification-every-30-minutes
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_INTERVAL_MINUTES=30
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_TASK_QUEUE=automation-control
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_WINDOW_START_HOUR=8
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_WINDOW_START_MINUTE=30
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_WINDOW_END_HOUR=20
COBRANCAS_EQUIPMENT_RETRIEVAL_TRIGGER_SCHEDULE_WINDOW_END_MINUTE=30
